RUNPOD_API_KEY=your_runpod_api_key_here
HF_TOKEN=your_huggingface_token_here

# HuggingFace 모델 캐시 경로 (컨테이너 내부 경로 — docker-compose의 ./hf_cache 볼륨에 마운트됨)
HF_HOME=/app/hf_cache

# docker-compose 선택적 오버라이드
# METHODS=awq gptq fp8       # quantize/benchmark 서비스용 (기본값: awq gptq fp8)
# METHOD=awq                 # serve 서비스용 (기본값: awq)
# SERVE_PORT=8000            # API 서버 포트 (기본값: 8000)
